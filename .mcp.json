{
  "mcpServers": {
    "mermaid": {
      "url": "https://mcp.mermaidchart.com/mcp",
      "type": "http",
      "description": "Mermaid diagram generation for architecture and documentation"
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "description": "shadcn-ui component installation and management"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--isolated"
      ]
    }
  }
}